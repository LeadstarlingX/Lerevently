{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080"
      }
    }
  },
  "ConnectionStrings": {
    "Database": "Host=lerevently.db;Port=5432;Database=lereventlydb_docker;User Id=postgres;Password=postgres;Include Error Detail=true",
    "Cache": "lerevently.redis:6379",
    "Queue": "amqp://lerevently-queue:5672"
  },
  "Authentication": {
    "Audience": "account",
    "TokenValidationParameters": {
      "ValidIssuers": [
        "http://lerevently.identity:8080/realms/lerevently",
        "http://localhost:8001/realms/lerevently"
      ]
    },
    "MetadataAddress": "http://lerevently.identity:8080/realms/lerevently/.well-known/openid-configuration",
    "RequireHttpsMetadata": false
  },
  "KeyCloak": {
    "HealthUrl": "http://lerevently.identity:8080"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://lerevently.seq:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "Lerevently.Api"
    }
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://lerevently.jaeger:4317"
}
