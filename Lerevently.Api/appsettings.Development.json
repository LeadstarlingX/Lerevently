{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5433;Database=lereventlydb_docker;User Id=postgres;Password=postgres;Include Error Detail=true",
    "Cache": "localhost:6379"
  },
  "Authentication": {
    "Audience": "account",
    "TokenValidationParameters": {
      "ValidIssuers": [
        "http://lerevently.identity:8080/realms/lerevently",
        "http://localhost:8001/realms/lerevently"
      ]
    },
    "MetadataAddress": "http://localhost:8001/realms/lerevently/.well-known/openid-configuration",
    "RequireHttpsMetadata": false
  },
  "KeyCloak": {
    "HealthUrl": "http://localhost:8001/health/"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "Lerevently.Api"
    }
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317"
}
